rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "gb580671@gmail.com";
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
